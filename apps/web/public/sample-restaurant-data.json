  "about": {
    "title": "Our Story",
    "content": "Sakura Ramen was born from a simple idea: bring authentic Japanese ramen to the local community using time-honored techniques and the freshest ingredients. What started as a small family kitchen has grown into a beloved neighborhood gathering place where friends and families come together over steaming bowls of handmade noodles.",
    "shortDescription": "Family-owned ramen shop since 2010, specializing in tonkotsu and miso ramen.",
    "mission": "To share the warmth and comfort of authentic Japanese ramen with every bowl we serve.",
    "philosophy": "Omotenashi — the art of wholehearted hospitality. Every guest is family.",
    "additionalContent": [
      "Our broth is simmered for 36 hours using locally sourced pork bones, resulting in a rich, velvety texture that defines our signature style.",
      "All noodles are made fresh daily in-house using traditional techniques passed down through generations.",
      "We source seasonal vegetables and premium proteins to ensure the highest quality in every dish."
    ],
