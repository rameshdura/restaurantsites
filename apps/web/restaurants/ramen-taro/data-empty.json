  "about": {
    "representative": {
      "name": "Takeshi Yamamoto",
      "position": "Master Chef & Founder",
      "message": "Quality is the heartbeat of our kitchen. Every bowl I serve is a tribute to the traditions I learned in Fukuoka, brought to life with passion for our guests in Tokyo.",
      "story": "Takeshi started his journey in 1985 at a small street stall. He believes that the essence of a great ramen lies in the patience of simmering the broth for 48 hours and the connection built with every customer who walks through our doors.",
