  "reviews": [
    {
      "id": "review-1",
      "author": "Aarav Patel",
      "rating": 5,
      "date": "2026-04-15",
      "comment": "The Everest Chicken Momos here are hands down the best in town! Reminds me of the local eateries in Kathmandu. Tastes absolutely fresh and flavorful.",
      "source": "Google Reviews"
    },
    {
      "id": "review-2",
      "author": "Sarah Jenkins",
      "rating": 5,
      "date": "2026-04-10",
      "comment": "First time trying Nepali food and I am in love! The Everest Dal Bhat Thali was an incredible variety of flavors. Highly recommend the Mango Lassi too.",
      "source": "Google Reviews"
    },
    {
      "id": "review-3",
      "author": "Rajesh Sharma",
      "rating": 4,
      "date": "2026-04-05",
      "comment": "Excellent Goat Curry and fresh Naan. The tandoor grill items are very authentic. Service was a bit busy but extremely polite.",
      "source": "Google Reviews"
    },
    {
      "id": "review-4",
      "author": "Elena Rostova",
      "rating": 5,
      "date": "2026-03-28",
      "comment": "A gem of a restaurant! The Palak Paneer was perfectly creamy, and the Gulab Jamun served warm at the end was outstanding. Warm and cozy atmosphere.",
      "source": "Google Reviews"
    }
  ],
